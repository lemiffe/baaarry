---
import { site } from "../data/site";
import CtaButton from "./CtaButton.astro";
---

<section class="bg-bg px-6 py-20 text-center">
  <div class="mx-auto max-w-2xl">
    <h2 class="text-2xl font-bold sm:text-3xl">Pay what you can. Or nothing at all.</h2>
    <p class="mt-6 text-lg leading-relaxed text-muted">
      Baaarry is pay-what-you-can; set your own price if it's earning its place in your
      workflow, or download it free if money's tight. No trial timer, no locked features, no
      account required. If it helps you ship better-sounding records, that's enough.
    </p>
    <div class="mt-10">
      <CtaButton href={site.downloadUrl}>Download Baaarry</CtaButton>
    </div>
  </div>
</section>
